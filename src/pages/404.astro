---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
---

<BaseLayout title="Halaman Tidak Ditemukan — DATAMATIKA 2026">
  <SiteHeader />
  <main id="main">
    <div class="not-found">
      <div class="not-found__code">404</div>
      <h1 class="not-found__title">Halaman Tidak Ditemukan</h1>
      <p class="not-found__text">
        Maaf, halaman yang Anda cari tidak ada. Kembali ke beranda untuk melihat informasi lainnya.
      </p>
      <a href="/" class="not-found__action">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M19 12H5M12 19l-7-7 7-7"/>
        </svg>
        Kembali ke Beranda
      </a>
    </div>
  </main>
  <SiteFooter />
</BaseLayout>
