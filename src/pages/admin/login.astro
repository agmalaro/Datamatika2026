---
import { isAuthenticated } from "../../lib/admin-auth";

if (isAuthenticated(Astro.cookies)) {
  return Astro.redirect("/admin");
}
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <title>Login Admin | DATAMATIKA 2026</title>
    <style>
      :root {
        --brand: #c04800;
        --brand-dark: #9a3a00;
        --brand-soft: rgba(192, 72, 0, 0.08);
        --ink: #1a1a1a;
        --muted: #5c5c5c;
        --white: #ffffff;
        --cream: #f7f4f1;
        --line: #ece2d8;
        --radius: 16px;
        --shadow: 0 20px 50px rgba(0, 0, 0, 0.12);
      }

      * { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
        background-color: var(--cream);
        background-image:
          linear-gradient(rgba(255, 255, 255, 0.72), rgba(255, 255, 255, 0.72)),
          repeating-linear-gradient(
            45deg,
            rgba(192, 72, 0, 0.08) 0,
            rgba(192, 72, 0, 0.08) 1px,
            transparent 1px,
            transparent 10px
          ),
          repeating-linear-gradient(
            -45deg,
            rgba(192, 72, 0, 0.06) 0,
            rgba(192, 72, 0, 0.06) 1px,
            transparent 1px,
            transparent 10px
          );
        background-size: auto, 98px 98px, 98px 98px;
        color: var(--ink);
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      .navbar {
        padding: 1.5rem 2rem;
        display: flex;
        justify-content: flex-start;
      }

      .btn-back {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        text-decoration: none;
        color: var(--muted);
        font-weight: 600;
        font-size: 0.9rem;
        transition: color 0.2s;
      }
      .btn-back:hover { color: var(--brand); }

      .main {
        flex: 1;
        display: grid;
        place-items: center;
        padding: 2rem 1rem 5rem;
      }

      .login-card {
        width: 100%;
        max-width: 440px;
        background: var(--white);
        border: 1px solid var(--line);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
        padding: 2.5rem;
        position: relative;
        overflow: hidden;
      }

      .login-card::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 5px;
        background: linear-gradient(90deg, var(--brand), var(--brand-dark));
      }

      .brand-header {
        text-align: center;
        margin-bottom: 2.5rem;
      }

      .brand-logo {
        height: 54px;
        width: auto;
        margin-bottom: 1rem;
      }

      .brand-header h1 {
        margin: 0;
        font-size: 1.5rem;
        font-weight: 800;
        color: var(--ink);
        letter-spacing: -0.02em;
      }

      .brand-header p {
        margin: 0.5rem 0 0;
        color: var(--muted);
        font-size: 0.95rem;
      }

      .form-group {
        margin-bottom: 1.25rem;
      }

      .form-group label {
        display: block;
        font-size: 0.88rem;
        font-weight: 700;
        margin-bottom: 0.5rem;
        color: var(--ink);
      }

      .form-group input {
        width: 100%;
        padding: 0.85rem 1rem;
        border-radius: 12px;
        border: 1.5px solid #e2e8f0;
        font-size: 1rem;
        font-family: inherit;
        transition: all 0.2s;
        background: #fcfdfd;
      }

      .form-group input:focus {
        outline: none;
        border-color: var(--brand);
        box-shadow: 0 0 0 4px var(--brand-soft);
        background: var(--white);
      }

      .error-box {
        background: #fff1f2;
        border: 1px solid #fecaca;
        color: #b91c1c;
        padding: 0.75rem 1rem;
        border-radius: 10px;
        font-size: 0.88rem;
        font-weight: 600;
        margin-bottom: 1.5rem;
        display: none;
      }
      .error-box.is-visible { display: block; animation: shake 0.4s ease; }

      @keyframes shake {
        0%, 100% { transform: translateX(0); }
        25% { transform: translateX(-5px); }
        75% { transform: translateX(5px); }
      }

      .btn-login {
        width: 100%;
        background: var(--brand);
        color: var(--white);
        border: none;
        padding: 1rem;
        border-radius: 12px;
        font-weight: 700;
        font-size: 1rem;
        cursor: pointer;
        transition: all 0.2s;
        box-shadow: 0 4px 12px rgba(192, 72, 0, 0.2);
      }

      .btn-login:hover {
        background: var(--brand-dark);
        transform: translateY(-1px);
        box-shadow: 0 8px 20px rgba(192, 72, 0, 0.3);
      }

      .btn-login:active { transform: translateY(0); }

      .hint {
        margin-top: 2rem;
        padding-top: 1.5rem;
        border-top: 1px dashed var(--line);
        font-size: 0.8rem;
        color: var(--muted);
        line-height: 1.5;
      }
      .hint code { background: #f1f5f9; padding: 2px 4px; border-radius: 4px; color: var(--brand-dark); }
    </style>
  </head>
  <body>
    <nav class="navbar">
      <a href="/" class="btn-back">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
        Kembali ke Beranda
      </a>
    </nav>

    <main class="main">
      <div class="login-card">
        <header class="brand-header">
          <img src="/favicon-32x32.png" alt="Logo" class="brand-logo" />
          <h1>Admin Portal</h1>
          <p>Silakan masuk untuk mengelola konten situs DATAMATIKA 2026.</p>
        </header>

        <form id="login-form">
          <div class="error-box" id="error-box"></div>

          <div class="form-group">
            <label for="username">Username</label>
            <input id="username" type="text" name="username" autocomplete="username" placeholder="Masukkan username" required />
          </div>

          <div class="form-group">
            <label for="password">Password</label>
            <input id="password" type="password" name="password" autocomplete="current-password" placeholder="••••••••" required />
          </div>

          <button type="submit" class="btn-login" id="submit-btn">Masuk Sekarang</button>
        </form>
      </div>
    </main>

    <script is:inline>
      const form = document.getElementById("login-form");
      const errorBox = document.getElementById("error-box");
      const submitBtn = document.getElementById("submit-btn");

      form?.addEventListener("submit", async (event) => {
        event.preventDefault();
        if (!(form instanceof HTMLFormElement)) return;
        
        errorBox.textContent = "";
        errorBox.classList.remove("is-visible");
        submitBtn.textContent = "Memproses...";
        submitBtn.disabled = true;

        const payload = {
          username: form.username.value,
          password: form.password.value,
        };

        try {
          const response = await fetch("/api/admin/login", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(payload),
          });

          if (!response.ok) {
            const data = await response.json().catch(() => ({ message: "Login gagal. Silakan periksa kembali." }));
            errorBox.textContent = data.message ?? "Kredensial tidak valid.";
            errorBox.classList.add("is-visible");
            submitBtn.textContent = "Masuk Sekarang";
            submitBtn.disabled = false;
            return;
          }

          window.location.href = "/admin";
        } catch (err) {
          errorBox.textContent = "Terjadi kesalahan koneksi ke server.";
          errorBox.classList.add("is-visible");
          submitBtn.textContent = "Masuk Sekarang";
          submitBtn.disabled = false;
        }
      });
    </script>
  </body>
</html>

