      function setStatus(message, type) {
        if (!status) return;
        status.textContent = message;
        status.className = type === "ok" ? "ok" : type === "err" ? "err" : "";
      }

      function showToast(message, type = "loading", ttl = 2200) {
        if (!(toast instanceof HTMLElement)) return;
        if (toastTimer) clearTimeout(toastTimer);
        toast.textContent = message;
        toast.className = `toast toast--${type} is-visible`;
        toastTimer = setTimeout(() => {
          toast.classList.remove("is-visible");
        }, ttl);
      }

      function setSavingUi(isSaving) {
        if (saveBtn instanceof HTMLButtonElement) {
          saveBtn.disabled = isSaving;
          saveBtn.textContent = isSaving ? "Menyimpan..." : "Simpan Perubahan";
        }
        if (saveProgress) {
          saveProgress.classList.toggle("is-loading", isSaving);
          saveProgress.setAttribute("aria-hidden", isSaving ? "false" : "true");
        }
      }

      function formatDateLabelFromInput(value) {
        if (typeof value !== "string" || !value) return "";
        const date = new Date(`${value}T00:00:00`);
        if (Number.isNaN(date.getTime())) return value;
        return new Intl.DateTimeFormat("id-ID", {
          day: "numeric",
          month: "long",
          year: "numeric",
        }).format(date);
      }

      function updateEventDatePreview() {
        if (!(eventStartsAtInput instanceof HTMLInputElement)) return;
        if (!(eventDatePreviewInput instanceof HTMLInputElement)) return;
        const dateValue = eventStartsAtInput.value.split("T")[0] ?? "";
        eventDatePreviewInput.value = formatDateLabelFromInput(dateValue);
      }

      function normalizePreviewUrl(url) {
        if (typeof url !== "string") return "/patterns/empty.svg";
        const cleaned = url.trim().replace(/^["']|["']$/g, "");
        if (!cleaned) return "/patterns/empty.svg";
        if (cleaned.startsWith("blob:") || cleaned.startsWith("data:")) return cleaned;
        if (cleaned.startsWith("http://") || cleaned.startsWith("https://")) return cleaned;
        if (cleaned.startsWith("/")) return cleaned;
        return `/${cleaned}`;
      }

      function setPreviewSource(img, url) {
        if (!(img instanceof HTMLImageElement)) return;
        const previousSrc = img.currentSrc || img.src;
        img.onerror = () => {
          img.onerror = null;
          if (previousSrc && !previousSrc.includes("/patterns/empty.svg")) {
            img.src = previousSrc;
          } else {
            img.src = "/patterns/empty.svg";
          }
        };
        img.src = normalizePreviewUrl(url);
      }

      function setHeroPreview(url) {
        if (!(heroBgPreview instanceof HTMLImageElement)) return;
        setPreviewSource(heroBgPreview, url);
