        if (!item) return;
        const preview = item.querySelector(".speaker-preview");
        setPreviewSource(preview, URL.createObjectURL(target.files[0]));
      });

      form?.addEventListener("submit", async (event) => {
        event.preventDefault();
        if (!(form instanceof HTMLFormElement)) return;
        setSavingUi(true);
        showToast("Sedang menyimpan perubahan...", "loading", 60000);
        const startedAt = Date.now();

        const timeline = form.timeline.value
          .split("\n")
          .map((line) => line.trim())
          .filter(Boolean)
          .map((line) => line.split("|").map((x) => x.trim()))
          .map(([date, label]) => ({ date: date ?? "", label: label ?? "" }))
          .filter((item) => item.date && item.label);
        const guideFlowSteps = form.guideFlowSteps.value
          .split("\n")
          .map((line) => line.trim())
          .filter(Boolean);
        const agendaItems = form.agendaRows.value
          .split("\n")
          .map((line) => line.trim())
          .filter(Boolean)
          .map((line) => line.split("|").map((x) => x.trim()))
          .map(([day, time, agenda, detail]) => ({
            day: day ?? "",
            time: time ?? "",
            agenda: agenda ?? "",
            ...(detail ? { detail } : {}),
          }))
          .filter((item) => item.day && item.time && item.agenda);

        const speakers = readSpeakers();
        const partners = readPartners();
        const gallery = readGallery();

        const payload = {
          siteMeta: {
            title: form.title.value,
            description: form.description.value,
            publishedUrl: form.publishedUrl.value,
            registrationUrl: form.registrationUrl.value,
            orgLine: form.orgLine.value,
            mapsAddress: form.mapsAddress.value,
            mapsEmbedUrl: form.mapsEmbedUrl.value,
            heroBg: form.heroBg.value,
            heroLogo: form.heroLogo.value,
            eventStartsAt: form.eventStartsAt.value,
            eventDateLabel: formatDateLabelFromInput((form.eventStartsAt.value || "").split("T")[0] || ""),
          },
          about: {
            heading: form.aboutHeading.value,
            body: form.aboutBody.value,
            image: form.aboutImage.value,
          },
          timeline,
          uploadNote: {
            title: form.uploadNoteTitle.value,
            body: form.uploadNoteBody.value,
            primaryLabel: form.uploadNotePrimaryLabel.value,
            primaryUrl: form.uploadNotePrimaryUrl.value,
            secondaryLabel: form.uploadNoteSecondaryLabel.value,
            secondaryUrl: form.uploadNoteSecondaryUrl.value,
          },
          guide: {
            flowTitle: form.guideFlowTitle.value,
            flowSteps: guideFlowSteps,
            flowImage: form.guideFlowImage.value,
            templateLabel: form.guideTemplateLabel.value,
            templateUrl: form.guideTemplateUrl.value,
            fee: {
              type: form.guideFeeType.value === "paid" ? "paid" : "free",
              freeText: form.guideFeeFreeText.value,
              paidAmount: form.guideFeePaidAmount.value,
              paidAccountNumber: form.guideFeePaidAccountNumber.value,
              paidAccountName: form.guideFeePaidAccountName.value,
            },
          },
          agenda: {
            title: form.agendaTitle.value,
            intro: form.agendaIntro.value,
            items: agendaItems,
          },
          timelineImage: form.timelineImage.value,
          speakers,
          partners,
          gallery,
        };

        setStatus("Menyimpan...", "");
        try {
          const response = await fetch("/api/admin/content", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(payload),
          });

          if (!response.ok) {
            const data = await response.json().catch(() => ({ message: "Gagal menyimpan." }));
            setStatus(data.message ?? "Gagal menyimpan.", "err");
            showToast(data.message ?? "Gagal menyimpan.", "err");
            return;
          }

          setStatus("Konten berhasil disimpan.", "ok");
          showToast("Perubahan berhasil disimpan.", "ok");
        } catch {
          setStatus("Gagal menyimpan. Periksa koneksi atau server lokal.", "err");
          showToast("Gagal menyimpan. Periksa koneksi/server.", "err");
        } finally {
          const elapsed = Date.now() - startedAt;
          const minimumVisible = 700;
          if (elapsed < minimumVisible) {
            await new Promise((resolve) => setTimeout(resolve, minimumVisible - elapsed));
          }
          setSavingUi(false);
        }
      });

      changePasswordBtn?.addEventListener("click", async () => {
        if (!(currentPasswordInput instanceof HTMLInputElement)) return;
        if (!(nextPasswordInput instanceof HTMLInputElement)) return;
        if (!(confirmPasswordInput instanceof HTMLInputElement)) return;

        const payload = {
          currentPassword: currentPasswordInput.value,
          nextPassword: nextPasswordInput.value,
          confirmPassword: confirmPasswordInput.value,
        };

        showToast("Memperbarui password...", "loading", 20000);
        try {
          const response = await fetch("/api/admin/password", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(payload),
          });

          const data = await response.json().catch(() => ({ message: "Gagal update password." }));
          const msg = data.message ?? "Gagal update password.";
          setStatus(msg, response.ok ? "ok" : "err");
          if (response.ok) {
            showToast(msg, "ok");
            currentPasswordInput.value = "";
            nextPasswordInput.value = "";
            confirmPasswordInput.value = "";
          } else {
            showToast(msg, "err");
          }
        } catch {
          const msg = "Gagal memperbarui password. Periksa koneksi/server.";
          setStatus(msg, "err");
          showToast(msg, "err");
        }
      });

      logoutBtn?.addEventListener("click", async () => {
        await fetch("/api/admin/logout", { method: "POST" });
        window.location.href = "/admin/login";
      });
    </script>
