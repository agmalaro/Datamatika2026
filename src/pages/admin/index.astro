          <img class="speaker-preview" width="200" height="150" style="object-fit:contain;display:block;" src="${normalizePreviewUrl(speaker.image || "/patterns/empty.svg")}" alt="Preview speaker" onerror="this.onerror=null;this.src='/patterns/empty.svg';" />
          <div class="speaker-actions">
