---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { getSiteData } from "../data/site";

const { gallery } = await getSiteData();
---

<BaseLayout title="Galeri Seminar | DATAMATIKA 2026">
  <SiteHeader />
  <main id="main">
    <section class="section section--gallery-page">
      <div class="wrap gallery-page">
        <h1 class="heading-accent heading-accent--lg">Galeri Seminar</h1>
        {
          gallery.length > 0 ? (
            <div class="gallery-grid">
              {gallery.map((item) => (
                <figure class="gallery-card reveal">
                  <img src={item.src} alt={item.caption || "Foto kegiatan seminar"} loading="lazy" decoding="async" />
                  {item.caption && <figcaption>{item.caption}</figcaption>}
                </figure>
              ))}
            </div>
          ) : (
            <p class="gallery-empty">Belum ada foto galeri yang ditampilkan.</p>
          )
        }
      </div>
    </section>
  </main>
  <SiteFooter />
</BaseLayout>

